{
  "name": "mineradio-web",
  "productName": "Mineradio Web",
  "version": "1.1.1-web",
  "description": "沉浸式音乐播放器 Web 版 — 融合天气电台、歌词舞台、粒子视觉和 3D 歌单架。",
  "author": "Mineradio",
  "license": "GPL-3.0",
  "main": "server.js",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "start:prod": "HOST=0.0.0.0 PORT=3000 node server.js",
    "test": "jest --verbose --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint server.js dj-analyzer.js tests/",
    "lint:fix": "eslint --fix server.js dj-analyzer.js tests/",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "syntax-check": "node --check server.js && node --check dj-analyzer.js"
  },
  "dependencies": {
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.9.4"
  }
}
